{
  "bindings": {
    "/actions/main": {
      "sources": [
        {
          "path": "/user/hand/left/input/y",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/toggle_panel" }
          }
        },
        {
          "path": "/user/hand/right/input/b",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/toggle_panel" }
          }
        },
        {
          "path": "/user/hand/left/input/trigger",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/interact" }
          }
        },
        {
          "path": "/user/hand/right/input/trigger",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/interact" }
          }
        }
      ]
    }
  },
  "controller_type": "oculus_touch",
  "description": "Default bindings for ExfilZone Wrist Tracker",
  "name": "ExfilZone Wrist Tracker defaults (Touch)"
}
